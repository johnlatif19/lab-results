{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*\\.ejs)",
      "dest": "/$1",
      "status": 404
    },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}
